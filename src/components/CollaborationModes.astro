---
import { Icon } from 'astro-icon/components'
---

<div class="grid gap-6 md:grid-cols-2">
  <!-- Project Mode -->
  <div class="card-base group relative overflow-hidden px-6 py-8 transition hover:border-[var(--primary)] hover:shadow-lg dark:hover:bg-gray-800">
    <!-- Background accent -->
    <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-[var(--primary)] opacity-5 transition group-hover:opacity-10"></div>

    <div class="relative z-10">
      <!-- Title -->
      <h3 class="mb-3 text-xl font-bold text-neutral-900 dark:text-neutral-50">
        Project Mode
      </h3>

      <!-- Description -->
      <p class="text-neutral-600 dark:text-neutral-300 leading-relaxed">
        We will break down your project into modules with price and delivery times.
      </p>
    </div>
  </div>

  <!-- Service Mode -->
  <div class="card-base group relative overflow-hidden px-6 py-8 transition hover:border-[var(--primary)] hover:shadow-lg dark:hover:bg-gray-800">
    <!-- Background accent -->
    <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-[var(--primary)] opacity-5 transition group-hover:opacity-10"></div>

    <div class="relative z-10">
      <!-- Title -->
      <h3 class="mb-3 text-xl font-bold text-neutral-900 dark:text-neutral-50">
        Service Mode
      </h3>

      <!-- Description -->
      <p class="text-neutral-600 dark:text-neutral-300 leading-relaxed">
        I will estimate your requested tasks (measured in "man-days") according to its complexity.
      </p>
    </div>
  </div>
</div>
