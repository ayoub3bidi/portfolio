---
import projectsData from '@/constants/projects'
import I18nKey from '@/i18n/i18nKey'
import { i18n } from '@/i18n/translation'
import MainGridLayout from '@/layouts/MainGridLayout.astro'
import { projectId, sortProjectsForPage } from '@/utils/projects'
import TimelineSidebar from '@components/misc/TimelineSidebar.svelte'
import ProjectCard from '@components/projects/ProjectCard.astro'
import ProjectsToolbar from '@components/projects/ProjectsToolbar.svelte'

const sortedProjects = sortProjectsForPage(projectsData)

const projectTypes = ['All', ...new Set(projectsData.map(p => p.type))]
const projectCounts: Record<string, number> = {
  All: projectsData.length,
  ...Object.fromEntries(
    projectTypes
      .filter(type => type !== 'All')
      .map(type => [
        type,
        projectsData.filter(project => project.type === type).length,
      ]),
  ),
}

const typesJson = JSON.stringify(projectTypes)
const countsJson = JSON.stringify(projectCounts)
---

<MainGridLayout title={i18n(I18nKey.projects)} description={i18n(I18nKey.projects)}>
  <a
    href="#projects-cards-container"
    class="pointer-events-none fixed left-4 top-0 z-[100] -translate-y-full rounded-b-md bg-[var(--primary)] px-4 py-2 text-sm font-medium text-white opacity-0 transition focus:pointer-events-auto focus:translate-y-0 focus:opacity-100 focus:outline-none motion-reduce:transition-none"
  >
    Skip to project list
  </a>

  <ProjectsToolbar client:visible typesJson={typesJson} countsJson={countsJson} />

  <div
    class="grid w-full grid-cols-1 gap-4 px-2 sm:gap-6 sm:px-2 lg:grid-cols-2"
    id="projects-cards-container"
  >
    {
      sortedProjects.map(project => (
        <ProjectCard
          project={project}
          projectId={projectId(project, projectsData.indexOf(project))}
        />
      ))
    }
  </div>

  <TimelineSidebar slot="after-main" client:visible />
</MainGridLayout>
